  create view "warehouse"."main"."stg_headlines__dbt_tmp" as (
    -- stg_headlines.sql
-- Mapping fact_articles to the 'stg_headlines' expected by marks/entity_trend.sql



SELECT
    fa.article_key as Headline_ID,
    ds.source_name as Source_Name,
    fa.translated_headline,
    fa.polarity,
    fa.sentiment_label,
    dd.full_date as Date_Extracted
FROM "warehouse"."main"."fact_articles" fa
JOIN "warehouse"."main"."dim_date" dd ON fa.date_key = dd.date_key
JOIN "warehouse"."main"."dim_source" ds ON fa.source_key = ds.source_key
  );

[0m11:33:14.644186 [debug] [Thread-2 (]: On model.news_warehouse.stg_articles: /* {"app": "dbt", "dbt_version": "1.11.11", "profile_name": "news_warehouse", "target_name": "dev", "node_id": "model.news_warehouse.stg_articles"} */

  
  create view "warehouse"."main"."stg_articles__dbt_tmp" as (
    -- stg_articles.sql
-- Staging model: joins fact_articles with dimension tables to produce
-- a clean, denormalized view of all articles for downstream analytics.



SELECT
    fa.article_key,
    fa.original_headline,
    fa.translated_headline,
    fa.polarity,
    fa.sentiment_label,

    -- Source dimension
    ds.source_name,
    ds.language_code,
    ds.region,
    ds.base_url,

    -- Date dimension
    dd.full_date       AS scrape_date,
    dd.day,
    dd.month,
    dd.year,
    dd.day_of_week,
    dd.week_of_year,
    dd.quarter,
    dd.is_weekend,

    -- Computed fields
    LENGTH(fa.translated_headline) AS headline_length,
    CASE
        WHEN fa.polarity > 0.05  THEN 'positive'
        WHEN fa.polarity < -0.05 THEN 'negative'
        ELSE 'neutral'
    END AS polarity_bucket

FROM fact_articles fa
LEFT JOIN dim_source ds ON fa.source_key = ds.source_key
LEFT JOIN dim_date dd   ON fa.date_key = dd.date_key
  );

