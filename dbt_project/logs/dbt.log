    de.entity_label as Entity_Label,
    bae.article_key as Headline_ID
FROM "news_warehouse"."main"."dim_entity" de
JOIN "news_warehouse"."main"."bridge_article_entity" bae ON de.entity_key = bae.entity_key
  );

